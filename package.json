{
  "name": "@leaperone/remote-au",
  "version": "0.0.0",
  "description": "N→1 LAN audio aggregation CLI — multiple senders capture audio, one receiver mixes and plays it back. Go + miniaudio, UDP (default) / TCP, auto-discovery.",
  "bin": {
    "remote-au": "bin/remote-au",
    "rau": "bin/remote-au"
  },
  "files": [
    "bin/remote-au"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test"
  },
  "optionalDependencies": {
    "@leaperone/remote-au-darwin-arm64": "0.0.0",
    "@leaperone/remote-au-darwin-x64": "0.0.0",
    "@leaperone/remote-au-linux-x64": "0.0.0",
    "@leaperone/remote-au-linux-arm64": "0.0.0",
    "@leaperone/remote-au-win32-x64": "0.0.0"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leaperone/remote-au.git"
  },
  "homepage": "https://github.com/leaperone/remote-au#readme",
  "bugs": {
    "url": "https://github.com/leaperone/remote-au/issues"
  },
