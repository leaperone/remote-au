#!/usr/bin/env node
'use strict';

// Launcher for the remote-au CLI (commands: `remote-au` and `rau`). The real
// program is a Go + cgo binary downloaded per platform at install time by
// scripts/postinstall.mjs into vendor/. This shim execs it, forwarding all
// arguments and stdio and propagating the exit code.

const { spawnSync } = require('node:child_process');
const { join } = require('node:path');
const { existsSync } = require('node:fs');

const platform = process.platform;
const arch = process.arch;
const exe = platform === 'win32' ? 'remote-au.exe' : 'remote-au';
const binary = join(__dirname, '..', 'vendor', exe);

if (!existsSync(binary)) {
  console.error(`remote-au: native binary not found at ${binary}.`);
  console.error(`Platform: ${platform}-${arch}.`);
  console.error('The postinstall download may have been skipped (e.g. --ignore-scripts)');
  console.error('or your platform is unsupported (darwin-arm64, darwin-x64, linux-x64,');
  console.error('linux-arm64, win32-x64).');
  console.error('Reinstall allowing scripts:  npm install -g @leaperone/remote-au');
  console.error('Or build from source: https://github.com/leaperone/remote-au');
  process.exit(1);
}

const result = spawnSync(binary, process.argv.slice(2), { stdio: 'inherit' });
if (result.error) {
  console.error(`remote-au: failed to launch ${binary}: ${result.error.message}`);
  process.exit(1);
}
if (result.signal) {
  process.exit(1);
}
process.exit(result.status === null ? 1 : result.status);
